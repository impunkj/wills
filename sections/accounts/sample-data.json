    "models": {
      "accountEntries": "Each account entry represents a lead that has been assigned from Sales CRM to the Accounts team for payment confirmation and eventual conversion to a customer.",
      "invoices": "Invoices are GST-compliant billing documents — either Proforma Invoices (PI) or Tax Invoices — issued to leads/customers with automatic CGST+SGST or IGST calculation based on buyer/seller state.",
      "payments": "Payments are recorded transactions against invoices, supporting partial payments with automatic balance tracking and multiple payment modes (NEFT, UPI, Cheque, etc.).",
      "refunds": "Refunds are requests initiated against payment records, following a multi-level approval workflow and triggering auto-generation of GST-compliant Credit Notes."
    },
    "relationships": [
      "Each Account Entry represents a Lead assigned from Sales CRM for payment processing",
      "Each Account Entry can have one or more Invoices (Proforma and Tax)",
      "Each Invoice can have one or more Payments (supporting partial payments)",
      "Each Payment can have at most one Refund request",
      "Account Entry is converted to a Customer after full payment confirmation"
    ]
