{
  "name": "wills24-admin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seed": "tsc -p tsconfig.server.json && node -e \"require('fs').writeFileSync('dist/package.json',JSON.stringify({type:'commonjs'}))\" && node dist/seed.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "start:dev": "tsc -p tsconfig.server.json && node -e \"require('fs').writeFileSync('dist/package.json',JSON.stringify({type:'commonjs'}))\" && node dist/main.js",
    "start:prod": "node dist/main"
  },
